# =============================================================================
# VPP Italia — Variables d'environnement
# Copier ce fichier en .env et compléter les valeurs
# JAMAIS committer .env dans git
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                          # development | staging | production
APP_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Europe/Rome

# -----------------------------------------------------------------------------
# Base de données — TimescaleDB (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vpp:password@localhost:5432/vpp_italia
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false                          # true en dev pour voir les requêtes SQL

# Migrations Alembic
ALEMBIC_DATABASE_URL=postgresql://vpp:password@localhost:5432/vpp_italia

# -----------------------------------------------------------------------------
# AWS — Région Milan (eu-south-1)
# -----------------------------------------------------------------------------
AWS_REGION=eu-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET_TELEMETRY=vpp-italia-telemetry-prod
AWS_S3_BUCKET_REPORTS=vpp-italia-reports-prod
AWS_SECRETS_MANAGER_PREFIX=vpp-italia/prod

# -----------------------------------------------------------------------------
# Kafka / Amazon MSK — Télémétrie batteries temps réel
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BATTERY_READINGS=battery.readings
KAFKA_TOPIC_DISPATCH_COMMANDS=dispatch.commands
KAFKA_TOPIC_MARKET_SIGNALS=market.signals
KAFKA_CONSUMER_GROUP_ID=vpp-api
KAFKA_SECURITY_PROTOCOL=PLAINTEXT             # SASL_SSL en production
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# -----------------------------------------------------------------------------
# Authentification JWT
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# GME — Gestore dei Mercati Energetici
# API soumission offres MGP, MI, MSD
# -----------------------------------------------------------------------------
GME_API_BASE_URL=https://api.mercatoelettrico.org/v1
GME_API_USERNAME=your-gme-username
GME_API_PASSWORD=your-gme-password
GME_PARTICIPANT_CODE=IT_VPP_001               # Code participant attribué par GME
GME_SANDBOX_MODE=true                         # false en production

# -----------------------------------------------------------------------------
# Terna — Gestionnaire réseau transport
# API soumission offres MSD, MB, UVAM
# -----------------------------------------------------------------------------
TERNA_API_BASE_URL=https://api.terna.it/transparency/v1
TERNA_CLIENT_ID=your-terna-client-id
TERNA_CLIENT_SECRET=your-terna-client-secret
TERNA_UPCA_CODE=IT_UPCA_001                   # Code UPCA/agrégateur Terna
TERNA_SANDBOX_MODE=true                        # false en production

# -----------------------------------------------------------------------------
# Batteries — Configuration globale
# -----------------------------------------------------------------------------
BATTERY_POLL_INTERVAL_SECONDS=10              # Fréquence lecture télémétrie
BATTERY_COMMAND_TIMEOUT_SECONDS=30            # Timeout commande dispatch
BATTERY_SAFE_STATE_TIMEOUT_SECONDS=30        # Passage safe state si comm perdue
BATTERY_MIN_SOC_PERCENT=10                    # SoC minimum opérationnel
BATTERY_MAX_SOC_PERCENT=90                    # SoC maximum opérationnel

# Modbus TCP (batteries compatibles)
MODBUS_DEFAULT_PORT=502
MODBUS_DEFAULT_TIMEOUT_SECONDS=5
MODBUS_DEFAULT_RETRIES=3

# OCPP 2.0.1 (bornes de charge avancées)
OCPP_WEBSOCKET_PORT=9000
OCPP_HEARTBEAT_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Optimiseur dispatch
# -----------------------------------------------------------------------------
OPTIMIZER_HORIZON_HOURS=24                    # Horizon glissant optimisation
OPTIMIZER_RESOLUTION_MINUTES=15              # Granularité QH
OPTIMIZER_SOLVER=CBC                          # CBC | GLPK | GUROBI | CPLEX
GUROBI_LICENSE_FILE=/opt/gurobi/gurobi.lic  # Uniquement si OPTIMIZER_SOLVER=GUROBI
OPTIMIZER_MAX_SOLVE_TIME_SECONDS=60          # Timeout solveur

# Marges de sécurité soumission marché
MARKET_SUBMISSION_LEAD_TIME_MINUTES=5        # Marge avant deadline GME/Terna

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# PagerDuty alertes critiques
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-routing-key
PAGERDUTY_ENABLED=false                       # true en production

# Sentry (erreurs applicatives)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Redis — Cache et rate limiting
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# CORS (développement local)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
