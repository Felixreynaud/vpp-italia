# =============================================================================
# Exemple de terraform.tfvars — COPIER en terraform.tfvars et compléter
# Ne JAMAIS commiter terraform.tfvars (contient des secrets)
# =============================================================================

aws_region     = "eu-south-1"
aws_account_id = "123456789012"   # Remplacer par votre Account ID AWS
environment    = "staging"

# Réseau
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidr    = "10.0.1.0/24"
private_subnet_cidr_a = "10.0.10.0/24"
private_subnet_cidr_b = "10.0.11.0/24"
admin_cidr            = "203.0.113.0/32"  # Votre IP fixe (curl ifconfig.me)

# EC2
ec2_instance_type = "t3.medium"
ec2_ami_id        = "ami-0a6b545f62129c495"  # Ubuntu 22.04 LTS eu-south-1
ec2_public_key    = "ssh-rsa AAAAB3NzaC1yc2EAAAA... votre-cle-publique"

# RDS
db_instance_class = "db.t3.micro"
db_password       = "ChangeMe-MinimumSeizeCaractères!2024"
