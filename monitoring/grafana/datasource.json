{
  "apiVersion": 1,
  "datasources": [
    {
      "name": "TimescaleDB",
      "type": "postgres",
      "uid": "vpp-timescaledb",
      "url": "${RDS_ENDPOINT}:5432",
      "user": "vpp",
      "database": "vpp_italia",
      "secureJsonData": {
        "password": "${DB_PASSWORD}"
      },
      "jsonData": {
        "sslmode": "require",
        "maxOpenConns": 10,
        "maxIdleConns": 5,
        "connMaxLifetime": 14400,
        "postgresVersion": 1500,
        "timescaledb": true
      },
      "isDefault": true,
      "editable": false
    },
    {
      "name": "Prometheus",
      "type": "prometheus",
      "uid": "vpp-prometheus",
      "url": "http://localhost:9090",
      "access": "proxy",
      "jsonData": {
        "timeInterval": "15s",
        "queryTimeout": "60s",
        "httpMethod": "POST"
      },
      "isDefault": false,
      "editable": false
    }
  ]
}
